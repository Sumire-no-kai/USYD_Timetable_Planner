{
  "manifest_version": 3,
  "name": "USYD Timetable Planner",
  "version": "0.2.3",
  "description": "Capture classes, avoid clashes, and plan your USYD timetable preferences.",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "sidePanel", "downloads"],
  "host_permissions": [
    "https://timetable.sydney.edu.au/*"
  ],
  "action": {
    "default_title": "USYD Timetable Planner",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://timetable.sydney.edu.au/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
